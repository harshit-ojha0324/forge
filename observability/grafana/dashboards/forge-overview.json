{
  "uid": "forge-overview",
  "title": "Forge — Inference Platform Overview",
  "tags": ["forge", "llm", "inference"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Circuit Breaker (vLLM)",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "forge_breaker_state", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "HALF-OPEN", "color": "yellow" }, "2": { "text": "OPEN", "color": "red" } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests / s",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(forge_requests_total[30s]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Client-Visible Error %",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "100 * (sum(rate(forge_requests_total{outcome=~\"all_backends_failed|stream_error|error\"}[1m])) or vector(0)) / sum(rate(forge_requests_total[1m]))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache Hit Ratio",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "100 * sum(rate(forge_cache_events_total{result=\"hit\"}[5m])) / sum(rate(forge_cache_events_total{result=~\"hit|miss\"}[5m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "noValue": "no cacheable traffic" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "In Flight",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "forge_inflight_requests", "refId": "A" }],
      "fieldConfig": { "defaults": { "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Queue Waiting",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "forge_queue_waiting", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 8 }, { "color": "red", "value": 24 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Requests/s by Serving Backend",
      "description": "The failover picture: kill vLLM and watch traffic move to gemini with the total unchanged.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (backend) (rate(forge_requests_total{outcome=\"ok\"}[30s]))", "legendFormat": "{{backend}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 25, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Failovers & Load Shedding",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(forge_failover_total[30s]))", "legendFormat": "failover attempts/s", "refId": "A" },
        { "expr": "sum by (reason) (rate(forge_shed_total[30s]))", "legendFormat": "shed: {{reason}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "p95 Latency by Backend",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, backend) (rate(forge_request_duration_seconds_bucket[1m])))", "legendFormat": "p95 {{backend}}", "refId": "A" },
        { "expr": "histogram_quantile(0.50, sum by (le, backend) (rate(forge_request_duration_seconds_bucket[1m])))", "legendFormat": "p50 {{backend}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Time to First Token (p95, streaming)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, backend) (rate(forge_ttft_seconds_bucket[1m])))", "legendFormat": "{{backend}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 5 }, "noValue": "no streaming traffic" }, "overrides": [] }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Tokens/s by Tenant",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (tenant) (rate(forge_tokens_total[1m]))", "legendFormat": "{{tenant}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 25, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Admission Queue",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "forge_queue_waiting", "legendFormat": "waiting", "refId": "A" },
        { "expr": "forge_inflight_requests", "legendFormat": "in flight", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 } }, "overrides": [] }
    },
    {
      "id": 16,
      "type": "bargauge",
      "title": "Token Spend Today by Tenant",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (tenant) (increase(forge_tokens_total[24h]))", "legendFormat": "{{tenant}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Requests by Outcome",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (outcome) (rate(forge_requests_total[30s]))", "legendFormat": "{{outcome}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    }
  ]
}
